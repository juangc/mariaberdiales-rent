generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  admin
  tenant
}

enum DocumentKind {
  invoice
  contract
  other
}

enum UtilityType {
  electricity
  water
  gas
  other
}

enum DocumentStatus {
  information
  pending
  paid
  overdue
}

enum DocumentVisibility {
  shared
  private
}

model User {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  email        String     @unique(map: "users_email_unique") @db.VarChar(254)
  name         String     @db.VarChar(160)
  phone        String?    @db.VarChar(32)
  passwordSalt String     @map("password_salt") @db.Char(32)
  passwordHash String     @map("password_hash") @db.Char(128)
  role         UserRole
  active       Boolean    @default(true)
  createdAt    String     @map("created_at") @db.VarChar(32)
  sessions     Session[]
  documents    Document[] @relation("TenantDocuments")

  @@map("users")
}

model Session {
  tokenHash String @id @map("token_hash") @db.Char(64)
  userId    BigInt @map("user_id") @db.UnsignedBigInt
  expiresAt String @map("expires_at") @db.VarChar(32)
  createdAt String @map("created_at") @db.VarChar(32)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "sessions_user_fk")

  @@index([expiresAt], map: "sessions_expiry_idx")
  @@map("sessions")
}

model Document {
  id           BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  kind         DocumentKind
  utilityType  UtilityType?       @map("utility_type")
  title        String             @db.VarChar(120)
  period       String?            @db.VarChar(120)
  amountCents  BigInt?            @map("amount_cents")
  dueDate      String?            @map("due_date") @db.Char(10)
  status       DocumentStatus
  visibility   DocumentVisibility
  tenantId     BigInt?            @map("tenant_id") @db.UnsignedBigInt
  storageName  String             @unique(map: "documents_storage_name_unique") @map("storage_name") @db.VarChar(255)
  originalName String             @map("original_name") @db.VarChar(255)
  mimeType     String             @map("mime_type") @db.VarChar(100)
  sizeBytes    BigInt             @map("size_bytes") @db.UnsignedBigInt
  createdAt    String             @map("created_at") @db.VarChar(32)
  tenant       User?              @relation("TenantDocuments", fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "documents_tenant_fk")

  @@index([tenantId], map: "documents_tenant_idx")
  @@map("documents")
}
