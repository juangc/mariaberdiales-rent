  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node scripts/dev.mjs",
    "dev:static": "node scripts/serve.mjs",
    "build:css": "BROWSERSLIST_IGNORE_OLD_DATA=true tailwind -c ./tailwind.config.cjs -i ./assets/styles.css -o ./assets/tailwind.css --minify",
    "build": "npm run build:css && node scripts/build.mjs",
    "start": "node server/app.mjs",
    "start:deploy": "prisma migrate deploy && node server/app.mjs",
    "db:generate": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:baseline": "prisma migrate resolve --applied 20260716000000_init",
    "migrate:sqlite": "prisma migrate deploy && node scripts/migrate-sqlite-to-mysql.mjs"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
